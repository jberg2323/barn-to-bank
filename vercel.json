{
  "rewrites": [
    { "source": "/app/login", "destination": "/login.html" },
    { "source": "/app", "destination": "/barn-to-bank.html" },
    { "source": "/app/(.*)", "destination": "/barn-to-bank.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}